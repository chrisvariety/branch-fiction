{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Branch Fiction",
  "version": "0.1.0",
  "identifier": "com.lexikon.branchfiction",
  "build": {
    "beforeDevCommand": "pnpm build:sdk && pnpm build:worker:dev && pnpm build:bundled-extensions && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:sdk && pnpm build:worker && pnpm build:bundled-extensions && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Library",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "sql": {
      "preload": ["sqlite:branch-fiction.db"]
    },
    "updater": {
      "endpoints": [
        "https://github.com/chrisvariety/branch-fiction/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2RkNFNjA5NTIyQTUwNUIKUldSYlVDcFNDZWI4MXJRRkY3Q0M3c0F6UlA3aUJiaGhleDZIbHErWXFTS1ZpSFZ6VndtVzhYZTEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/deno"],
    "resources": {
      "../dist": "dist",
      "resources/pipeline-worker.bundle.js": "resources/pipeline-worker.bundle.js",
      "resources/extension-host.bundle.js": "resources/extension-host.bundle.js",
      "resources/test-provider.bundle.js": "resources/test-provider.bundle.js",
      "../packages/bundled-extensions/cyoa/manifest.json": "bundled-extensions/cyoa/manifest.json",
      "../packages/bundled-extensions/cyoa/dist": "bundled-extensions/cyoa/dist",
      "../packages/bundled-extensions/cyoa/seed.db.gz": "bundled-extensions/cyoa/seed.db.gz",
      "seed-books": "resources/seed-books"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
