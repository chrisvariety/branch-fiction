{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Branch Fiction",
  "version": "0.1.0",
  "identifier": "com.lexikon.branchfiction",
  "build": {
    "beforeDevCommand": "pnpm build:worker:dev && pnpm build:bundled-extensions && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:worker && pnpm build:bundled-extensions && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Library",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "sql": {
      "preload": ["sqlite:branch-fiction.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/deno"],
    "resources": {
      "../dist": "dist",
      "resources/pipeline-worker.bundle.js": "resources/pipeline-worker.bundle.js",
      "resources/extension-host.bundle.js": "resources/extension-host.bundle.js",
      "resources/test-provider.bundle.js": "resources/test-provider.bundle.js",
      "../packages/bundled-extensions/chat/manifest.json": "bundled-extensions/chat/manifest.json",
      "../packages/bundled-extensions/chat/dist": "bundled-extensions/chat/dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
