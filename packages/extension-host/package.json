{
  "name": "extension-host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bundle": "tsdown -c tsdown.config.ts",
    "typecheck": "tsc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
