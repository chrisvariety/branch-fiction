    "fmt:check": "oxfmt --check",
    "ci": "concurrently \"pnpm lint --fix\" \"pnpm fmt\""
  },
  "dependencies": {
    "@branch-fiction/extension-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/deno": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
