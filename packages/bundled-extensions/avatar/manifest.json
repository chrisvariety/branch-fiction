{
  "manifestVersion": "v1",
  "id": "@local/avatar",
  "name": "Talk to a Character",
  "version": "0.1.0",
  "author": "Chris McC",
  "description": "Bring a character to life as a real-time AI avatar. Pick a character, generate a reference portrait and personality from the book's own arcs, then have a face-to-face conversation powered by your choice of avatar, speech, and voice providers.",
  "repository": "https://github.com/chrisvariety/branch-fiction/tree/release/packages/bundled-extensions/avatar",
  "seed": "seed.db.gz",
  "bookData": [
    {
      "table": "avatars",
      "bookIdColumn": "book_id",
      "assetColumns": ["image_url"]
    }
  ],
  "path": {
    "phoneCompatible": false,
    "entry": "dist/index.html",
    "worker": "dist/worker.js",
    "window": { "width": 1180, "height": 860 }
  },
  "providers": [
    {
      "key": "text",
      "role": "Prompt augmentation (LLM)",
      "useSlot": "piText"
    },
    {
      "key": "image_generation_reference",
      "role": "Reference image generation",
      "options": [
        {
          "baseURL": "https://generativelanguage.googleapis.com/v1beta",
          "auth": { "kind": "header", "header": "x-goog-api-key" },
          "model": "gemini-3.1-flash-image-preview",
          "credentialHelp": "Get an API key from [Google AI Studio](https://aistudio.google.com)"
        },
        {
          "baseURL": "https://api.openai.com/v1",
          "auth": { "kind": "bearer" },
          "model": "gpt-image-2"
        },
        {
          "baseURL": "https://fal.run",
          "auth": { "kind": "bearer", "headerPrefix": "Key" },
          "model": "fal-ai/nano-banana-2",
          "credentialHelp": "Get an API key from [Fal](https://fal.ai/dashboard/keys)"
        }
      ]
    },
    {
      "key": "avatar",
      "role": "Avatar (talking face)",
      "options": [
        {
          "baseURL": "https://lemonslice.com",
          "providerName": "LemonSlice",
          "auth": { "kind": "header", "header": "X-API-Key" },
          "credentialHelp": "Get an API key from [LemonSlice](https://lemonslice.com/agents/api)"
        }
      ]
    },
    {
      "key": "speech_to_text",
      "role": "Speech to text",
      "options": [
        {
          "baseURL": "https://api.openai.com/v1",
          "providerName": "OpenAI",
          "auth": { "kind": "bearer" },
          "model": "gpt-4o-transcribe",
          "credentialHelp": "Use your [OpenAI API key](https://platform.openai.com/api-keys)"
        },
        {
          "baseURL": "https://generativelanguage.googleapis.com/v1beta",
          "providerName": "Gemini",
          "auth": { "kind": "header", "header": "x-goog-api-key" },
          "model": "gemini-3.5-flash",
          "credentialHelp": "Get an API key from [Google AI Studio](https://aistudio.google.com)"
        }
      ]
    },
    {
      "key": "text_to_speech",
      "role": "Text to speech (voice)",
      "options": [
        {
          "baseURL": "https://api.openai.com/v1",
          "providerName": "OpenAI",
          "auth": { "kind": "bearer" },
          "model": "gpt-4o-mini-tts",
          "credentialHelp": "Use your [OpenAI API key](https://platform.openai.com/api-keys)"
        },
        {
          "baseURL": "https://generativelanguage.googleapis.com/v1beta",
          "providerName": "Gemini",
          "auth": { "kind": "header", "header": "x-goog-api-key" },
          "model": "gemini-3.1-flash-tts-preview",
          "credentialHelp": "Get an API key from [Google AI Studio](https://aistudio.google.com)"
        }
      ]
    }
  ],
  "config": [
    {
      "key": "livekit_url",
      "label": "LiveKit URL",
      "type": "url",
      "required": true,
      "placeholder": "wss://your-project.livekit.cloud",
      "description": "Your LiveKit Cloud project URL"
    },
    {
      "key": "livekit_api_key",
      "label": "LiveKit API Key",
      "type": "text",
      "required": true,
      "description": "From your LiveKit Cloud project settings"
    },
    {
      "key": "livekit_api_secret",
      "label": "LiveKit API Secret",
      "type": "text",
      "required": true,
      "description": "From your LiveKit Cloud project settings (kept on this device, used to sign room tokens)"
    }
  ],
  "permissions": ["microphone"],
  "net": ["cloud.branchfiction.com", "*.livekit.cloud", "*.livekit.run"]
}
