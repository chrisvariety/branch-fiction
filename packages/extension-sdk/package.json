{
  "name": "@branch-fiction/extension-sdk",
  "version": "0.3.0",
  "description": "SDK and dev tooling for building Branch Fiction extensions.",
  "homepage": "https://github.com/chrisvariety/branch-fiction/tree/main/packages/extension-sdk",
  "license": "MIT",
  "author": "Chris McC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisvariety/branch-fiction.git",
    "directory": "packages/extension-sdk"
  },
  "bin": {
    "branch-fiction-extension-dev": "./dist/dev-cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    },
    "./pi-handle": {
      "types": "./dist/pi-handle.d.ts",
      "default": "./dist/pi-handle.js"
    },
    "./pi-ai": {
      "types": "./dist/pi-ai.d.ts",
      "default": "./dist/pi-ai.js"
    },
    "./llm/xml": {
      "types": "./dist/llm/xml.d.ts",
      "default": "./dist/llm/xml.js"
    },
    "./llm/prompt": {
      "types": "./dist/llm/prompt.d.ts",
      "default": "./dist/llm/prompt.js"
    },
    "./media/art-style": {
      "types": "./dist/media/art-style.d.ts",
      "default": "./dist/media/art-style.js"
    },
    "./media/generate-one-shot-image": {
      "types": "./dist/media/generate-one-shot-image.d.ts",
      "default": "./dist/media/generate-one-shot-image.js"
    },
    "./media/image-errors": {
      "types": "./dist/media/image-errors.d.ts",
      "default": "./dist/media/image-errors.js"
    },
    "./media/image-models": {
      "types": "./dist/media/image-models.d.ts",
      "default": "./dist/media/image-models.js"
    },
    "./media/image-retry": {
      "types": "./dist/media/image-retry.d.ts",
      "default": "./dist/media/image-retry.js"
    },
    "./media/image-types": {
      "types": "./dist/media/image-types.d.ts",
      "default": "./dist/media/image-types.js"
    },
    "./media/transform-url": {
      "types": "./dist/media/transform-url.d.ts",
      "default": "./dist/media/transform-url.js"
    },
    "./media/image-apis/gemini": {
      "types": "./dist/media/image-apis/gemini.d.ts",
      "default": "./dist/media/image-apis/gemini.js"
    },
    "./media/image-apis/openai": {
      "types": "./dist/media/image-apis/openai.d.ts",
      "default": "./dist/media/image-apis/openai.js"
    },
    "./models-catalog": {
      "types": "./dist/models-catalog.d.ts",
      "default": "./dist/models-catalog.js"
    },
    "./sdk-source": {
      "types": "./dist/sdk-source.d.ts",
      "default": "./dist/sdk-source.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "default": "./dist/dev.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./db": {
      "types": "./dist/db/types.d.ts",
      "default": "./dist/db/types.js"
    },
    "./db/iframe": {
      "types": "./dist/db/iframe.d.ts",
      "default": "./dist/db/iframe.js"
    },
    "./db/boolean-plugin": {
      "types": "./dist/db/boolean-plugin.d.ts",
      "default": "./dist/db/boolean-plugin.js"
    },
    "./db/worker": {
      "types": "./dist/db/worker.d.ts",
      "default": "./dist/db/worker.js"
    },
    "./db/parse-count": {
      "types": "./dist/db/parse-count.d.ts",
      "default": "./dist/db/parse-count.js"
    },
    "./worker/error-types": {
      "types": "./dist/worker/error-types.d.ts",
      "default": "./dist/worker/error-types.js"
    },
    "./worker/env-soft": {
      "types": "./dist/worker/env-soft.d.ts",
      "default": "./dist/worker/env-soft.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && pnpm vendor:bundle",
    "prepublishOnly": "pnpm build",
    "vendor:bundle": "pnpm --filter extension-host bundle && node scripts/copy-bundle.mjs",
    "typecheck": "tsc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "ci": "concurrently \"pnpm lint --fix\" \"pnpm fmt\""
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "catalog:",
    "@earendil-works/pi-ai": "catalog:",
    "@google/genai": "^2.9.0",
    "@hono/node-server": "^2.0.5",
    "@huggingface/jinja": "catalog:",
    "@stablelib/base64": "catalog:",
    "better-sqlite3": "catalog:",
    "css-select": "catalog:",
    "dom-serializer": "catalog:",
    "domhandler": "catalog:",
    "domutils": "catalog:",
    "hono": "^4.12.26",
    "htmlparser2": "catalog:",
    "kysely": "catalog:",
    "kysely-plugin-serialize": "catalog:",
    "openai": "^6.44.0",
    "p-retry": "^8.0.0",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
