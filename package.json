{
  "name": "branch-fiction",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "fetch:deno": "node scripts/fetch-deno.mjs",
    "fetch:deno:dev": "node scripts/fetch-deno.mjs --skip-if-exists",
    "bundle:worker": "pnpm --filter pipeline-worker bundle",
    "bundle:extension-host": "pnpm --filter extension-host bundle",
    "bundle:test-provider": "pnpm --filter test-provider bundle",
    "bundle:bundles": "pnpm bundle:worker && pnpm bundle:extension-host && pnpm bundle:test-provider",
    "build:worker": "pnpm fetch:deno && pnpm bundle:bundles",
    "build:worker:dev": "pnpm fetch:deno:dev && pnpm bundle:bundles",
    "build:bundled-extensions": "pnpm --filter \"./packages/bundled-extensions/*\" run build",
    "sign:extension": "node scripts/sign-extension.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc && tsc -p e2e/tsconfig.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "ci": "concurrently \"pnpm lint --fix\" \"pnpm fmt\"",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@branch-fiction/extension-sdk": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@earendil-works/pi-ai": "catalog:",
    "@stablelib/base64": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "colorthief": "^3.3.1",
    "css-select": "catalog:",
    "dom-serializer": "catalog:",
    "domhandler": "catalog:",
    "domutils": "catalog:",
    "htmlparser2": "catalog:",
    "kysely": "catalog:",
    "kysely-dialect-tauri": "^1.2.1",
    "kysely-plugin-serialize": "catalog:",
    "mdast-util-from-markdown": "catalog:",
    "mdast-util-to-markdown": "catalog:",
    "p-queue": "catalog:",
    "postcss": "catalog:",
    "qrcode.react": "^4.2.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "semver-parser": "^4.2.1",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tailwindcss-animate": "catalog:",
    "tokenx": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "catalog:",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "catalog:",
    "concurrently": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
